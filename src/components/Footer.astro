---
import { services } from "../data/services";
---

<footer class="site-footer">
	<div class="wrap">
		<div class="site-footer__grid">
			<div>
				<p class="site-footer__brand">Bizintellis</p>
				<p class="site-footer__lede">
					Independent Oracle Cloud advisory and delivery—clarity first, then disciplined execution from roadmap to run.
				</p>
			</div>
			<div>
				<p class="site-footer__label">Services</p>
				<ul class="site-footer__list">
					{
						services.map((s) => (
							<li>
								<a href={`/services/${s.slug}`}>{s.title}</a>
							</li>
						))
					}
				</ul>
			</div>
		</div>
		<p class="site-footer__legal">
			© {new Date().getFullYear()} Bizintellis. Typical offerings described here; scope is confirmed under engagement.
		</p>
	</div>
</footer>

<style>
	.site-footer {
		background: var(--footer-bg);
		color: var(--color-muted);
		padding: 3rem 0 2rem;
		margin-top: auto;
		border-top: 1px solid var(--color-border);
	}

	.site-footer__grid {
		display: grid;
		gap: 2rem;
		margin-bottom: 2rem;
	}

	@media (min-width: 720px) {
		.site-footer__grid {
			grid-template-columns: 1.2fr 1fr;
		}
	}

	.site-footer__brand {
		font-family: var(--font-display);
		font-size: 1.35rem;
		font-weight: 600;
		color: var(--color-ink);
		margin: 0 0 0.5rem;
	}

	.site-footer__lede {
		margin: 0;
		max-width: 36ch;
		line-height: 1.55;
	}

	.site-footer__label {
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-gold);
		margin: 0 0 0.75rem;
	}

	.site-footer__list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 0.4rem;
	}

	.site-footer__list a {
		color: var(--footer-link);
		text-decoration: none;
	}

	.site-footer__list a:hover {
		color: var(--color-ink);
	}

	.site-footer__legal {
		border-top: 1px solid var(--color-border);
		padding-top: 1.5rem;
		margin: 0;
		font-size: 0.875rem;
		color: var(--footer-legal);
	}
</style>
