---
import { services } from "../data/services";
import {
	siteFooterContact,
	siteFooterQuickLinks,
	siteFooterSocial,
} from "../data/siteFooter";
---

<footer class="site-footer">
	<div class="wrap">
		<div class="site-footer__grid">
			<div class="site-footer__col">
				<p class="site-footer__brand">Bizintellis</p>
				<p class="site-footer__tag">Oracle practice</p>
				<p class="site-footer__lede">
					Independent Oracle Cloud advisory and delivery—clarity first, then disciplined execution from roadmap to run.
				</p>
				<p class="site-footer__label site-footer__label--contact">Contact</p>
				<ul class="site-footer__list site-footer__contact">
					<li>
						<a href={`mailto:${siteFooterContact.email}`}>{siteFooterContact.email}</a>
					</li>
					<li>
						<a href={`tel:${siteFooterContact.phoneTel}`}>{siteFooterContact.phoneDisplay}</a>
					</li>
				</ul>
			</div>

			<div class="site-footer__col site-footer__col--middle">
				<p class="site-footer__label">Explore</p>
				<ul class="site-footer__list">
					{
						siteFooterQuickLinks.map((item) => (
							<li>
								<a href={item.href}>{item.label}</a>
							</li>
						))
					}
				</ul>
				<p class="site-footer__label site-footer__label--social">Social</p>
				<ul class="site-footer__social" aria-label="Social media">
					{
						siteFooterSocial.map((s) => (
							<li>
								<a
									href={s.href}
									class="site-footer__social-link"
									target="_blank"
									rel="noopener noreferrer"
									aria-label={`${s.label} (opens in a new tab)`}
								>
									{s.label === "LinkedIn" && (
										<svg class="site-footer__social-icon" width="20" height="20" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
											<path
												d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
											/>
										</svg>
									)}
									{s.label === "YouTube" && (
										<svg class="site-footer__social-icon" width="20" height="20" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
											<path
												d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
											/>
										</svg>
									)}
									{s.label === "X" && (
										<svg class="site-footer__social-icon" width="20" height="20" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
											<path
												d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
											/>
										</svg>
									)}
								</a>
							</li>
						))
					}
				</ul>
			</div>

			<div class="site-footer__col site-footer__col--services">
				<p class="site-footer__label">Services</p>
				<ul class="site-footer__list">
					{
						services.map((s) => (
							<li>
								<a href={`/services/${s.slug}`}>{s.title}</a>
							</li>
						))
					}
				</ul>
			</div>
		</div>
		<p class="site-footer__legal">© {new Date().getFullYear()} Bizintellis. All rights reserved.</p>
	</div>
</footer>

<style>
	.site-footer {
		background: var(--footer-bg);
		color: var(--color-muted);
		padding: 3rem 0 2rem;
		margin-top: auto;
		border-top: 1px solid var(--color-border);
	}

	.site-footer__grid {
		display: grid;
		gap: 2rem 2.5rem;
		margin-bottom: 2rem;
	}

	@media (min-width: 768px) {
		.site-footer__grid {
			grid-template-columns: minmax(0, 1.15fr) minmax(0, 1fr) minmax(0, 1fr);
			align-items: start;
		}
	}

	.site-footer__brand {
		font-family: var(--font-display);
		font-size: 1.35rem;
		font-weight: 600;
		color: var(--color-ink);
		margin: 0 0 0.25rem;
	}

	.site-footer__tag {
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--color-muted);
		margin: 0 0 0.75rem;
	}

	.site-footer__lede {
		margin: 0;
		max-width: 42ch;
		line-height: 1.55;
	}

	.site-footer__label {
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-gold);
		margin: 0 0 0.75rem;
	}

	.site-footer__label--contact {
		margin-top: 1.5rem;
	}

	.site-footer__label--social {
		margin-top: 1.25rem;
	}

	.site-footer__list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 0.4rem;
	}

	.site-footer__list a {
		color: var(--footer-link);
		text-decoration: none;
	}

	.site-footer__list a:hover {
		color: var(--color-ink);
	}

	.site-footer__contact a {
		word-break: break-word;
	}

	.site-footer__social {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.site-footer__social-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.5rem;
		height: 2.5rem;
		border-radius: 10px;
		border: 1px solid var(--color-border);
		background: color-mix(in oklab, var(--color-surface), transparent 30%);
		color: var(--footer-link);
		text-decoration: none;
		transition:
			color var(--dur-2) var(--ease-out-quint),
			background var(--dur-2) ease,
			border-color var(--dur-2) ease,
			transform var(--dur-2) var(--ease-out-quint);
	}

	.site-footer__social-link:hover {
		color: var(--color-ink);
		border-color: var(--color-border-strong);
		background: var(--color-surface-hover);
		transform: translateY(-2px);
	}

	.site-footer__social-link:focus-visible {
		outline: none;
		box-shadow: var(--ring);
	}

	.site-footer__social-icon {
		display: block;
		flex-shrink: 0;
	}

	.site-footer__col--services .site-footer__list {
		gap: 0.35rem;
	}

	@media (min-width: 768px) {
		.site-footer__col--services .site-footer__list {
			max-height: 16rem;
			overflow-y: auto;
			padding-right: 0.35rem;
			scrollbar-width: thin;
		}
	}

	.site-footer__legal {
		border-top: 1px solid var(--color-border);
		padding-top: 1.5rem;
		margin: 0;
		font-size: 0.875rem;
		color: var(--footer-legal);
	}
</style>
