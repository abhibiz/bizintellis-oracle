---
import ThemeToggle from "./ThemeToggle.astro";

const nav = [
	{ href: "/#audience", label: "Approach" },
	{ href: "/#services", label: "Services" },
	{ href: "/services", label: "All services" },
	{ href: "/contact", label: "Contact" },
];
---

<header class="site-header">
	<div class="wrap site-header__inner">
		<a href="/" class="site-header__brand">
			<span class="site-header__mark" aria-hidden="true"></span>
			<span class="site-header__title">Bizintellis</span>
			<span class="site-header__tag">Oracle practice</span>
		</a>
		<nav class="site-header__navlinks" aria-label="Primary">
			{
				nav.map((item) => (
					<a href={item.href} class="site-header__link">
						{item.label}
					</a>
				))
			}
		</nav>
		<div class="site-header__actions" aria-label="Header actions">
			<ThemeToggle />
			<a href="/contact" class="btn btn--primary site-header__cta">Start a conversation</a>
		</div>
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 50;
		background: linear-gradient(
			180deg,
			color-mix(in oklab, var(--header-bg), transparent 18%) 0%,
			var(--header-bg) 55%,
			color-mix(in oklab, var(--header-bg), transparent 70%) 100%
		);
		backdrop-filter: blur(14px);
		border-bottom: 1px solid var(--header-border, var(--color-border));
		box-shadow: 0 20px 60px rgba(0, 0, 0, 0.06);
	}

	.site-header__inner {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		gap: 1rem 1.25rem;
		padding: 1rem 0;
	}

	.site-header__brand {
		text-decoration: none;
		color: inherit;
		display: grid;
		grid-template-columns: auto 1fr;
		grid-template-rows: auto auto;
		column-gap: 0.65rem;
		align-items: center;
	}

	.site-header__mark {
		grid-row: span 2;
		width: 2.25rem;
		height: 2.25rem;
		border-radius: 10px;
		background: linear-gradient(145deg, var(--color-primary-soft), transparent), var(--header-mark-bg);
		border: 1px solid var(--color-border);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08), 0 10px 26px rgba(0, 0, 0, 0.18);
		position: relative;
	}

	.site-header__mark::after {
		content: "";
		position: absolute;
		inset: 22%;
		border: 1px solid rgba(255, 255, 255, 0.22);
		border-radius: 50%;
		box-shadow: 0 0 14px rgba(124, 58, 237, 0.22);
	}

	.site-header__title {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 1.35rem;
		letter-spacing: -0.01em;
		line-height: 1.1;
		color: var(--color-ink);
	}

	.site-header__tag {
		font-size: 0.72rem;
		color: var(--color-muted);
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	.site-header__navlinks {
		grid-column: 2;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.75rem 1.15rem;
		flex-wrap: wrap;
	}

	.site-header__actions {
		grid-column: 3;
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 0.65rem;
	}

	.site-header__link {
		font-size: 0.9rem;
		font-weight: 550;
		color: var(--color-muted);
		text-decoration: none;
		position: relative;
	}

	.site-header__link:hover {
		color: var(--color-ink);
	}

	.site-header__link::after {
		content: "";
		position: absolute;
		left: 0;
		right: 0;
		bottom: -0.55rem;
		height: 2px;
		border-radius: 999px;
		background: linear-gradient(90deg, transparent, var(--color-primary), transparent);
		opacity: 0;
		transform: scaleX(0.7);
		transition: opacity var(--dur-2) ease, transform var(--dur-2) var(--ease-out-quint);
	}

	.site-header__link:hover::after {
		opacity: 0.9;
		transform: scaleX(1);
	}

	.site-header__cta {
		padding: 0.55rem 1rem;
		font-size: 0.82rem;
	}

	@media (max-width: 860px) {
		.site-header__inner {
			grid-template-columns: 1fr;
		}

		.site-header__navlinks {
			grid-column: 1;
			justify-content: flex-start;
			margin-top: 0.25rem;
		}

		.site-header__actions {
			grid-column: 1;
			justify-content: flex-start;
		}
	}
</style>
