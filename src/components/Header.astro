---
import ThemeToggle from "./ThemeToggle.astro";

const nav = [
	{ href: "/#audience", label: "Approach" },
	{ href: "/#services", label: "Services" },
	{ href: "/services", label: "All services" },
	{ href: "/contact", label: "Contact" },
];
---

<header class="site-header">
	<div class="wrap site-header__inner">
		<a href="/" class="site-header__brand">
			<span class="site-header__mark" aria-hidden="true"></span>
			<span class="site-header__title">Bizintellis</span>
			<span class="site-header__tag">Oracle practice</span>
		</a>
		<nav class="site-header__nav" aria-label="Primary">
			{
				nav.map((item) => (
					<a href={item.href} class="site-header__link">
						{item.label}
					</a>
				))
			}
			<ThemeToggle />
			<a href="/contact" class="btn btn--primary site-header__cta">Start a conversation</a>
		</nav>
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 50;
		background: var(--header-bg);
		backdrop-filter: blur(14px);
		border-bottom: 1px solid var(--color-border);
	}

	.site-header__inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.9rem 0;
		flex-wrap: wrap;
	}

	.site-header__brand {
		text-decoration: none;
		color: inherit;
		display: grid;
		grid-template-columns: auto 1fr;
		grid-template-rows: auto auto;
		column-gap: 0.65rem;
		align-items: center;
	}

	.site-header__mark {
		grid-row: span 2;
		width: 2.25rem;
		height: 2.25rem;
		border-radius: 10px;
		background: linear-gradient(145deg, var(--color-gold-soft), transparent), var(--header-mark-bg);
		border: 1px solid var(--color-border);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
		position: relative;
	}

	.site-header__mark::after {
		content: "";
		position: absolute;
		inset: 22%;
		border: 1px solid rgba(212, 184, 122, 0.45);
		border-radius: 50%;
		box-shadow: 0 0 12px rgba(212, 184, 122, 0.15);
	}

	.site-header__title {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 1.35rem;
		letter-spacing: 0.02em;
		line-height: 1.1;
		color: var(--color-ink);
	}

	.site-header__tag {
		font-size: 0.72rem;
		color: var(--color-muted);
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	.site-header__nav {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.5rem 1.15rem;
	}

	.site-header__link {
		font-size: 0.9rem;
		font-weight: 500;
		color: var(--color-muted);
		text-decoration: none;
	}

	.site-header__link:hover {
		color: var(--color-ink);
	}

	.site-header__cta {
		padding: 0.55rem 1rem;
		font-size: 0.82rem;
	}
</style>
