---
const rawNumber = (import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? "").toString().trim();
const message = (import.meta.env.PUBLIC_WHATSAPP_MESSAGE ?? "").toString().trim();

const digitsOnly = rawNumber.replace(/[^\d]/g, "");
const href = digitsOnly
	? `https://wa.me/${digitsOnly}${message ? `?text=${encodeURIComponent(message)}` : ""}`
	: "";
---

{
	href ? (
		<a
			class="whatsapp-sticky"
			href={href}
			target="_blank"
			rel="noopener noreferrer"
			aria-label="Chat on WhatsApp"
			title="Chat on WhatsApp"
		>
			<img
				class="whatsapp-sticky__icon"
				src="/images/whatsapp-whats-app-svgrepo-com.svg"
				alt=""
				width="24"
				height="24"
				loading="eager"
				decoding="async"
			/>
			<span class="sr-only">Chat on WhatsApp</span>
		</a>
	) : null
}

