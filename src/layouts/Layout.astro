---
import "../styles/global.css";
import "../styles/animations.css";
import MotionInit from "../components/MotionInit.astro";
import WhatsAppSticky from "../components/WhatsAppSticky.astro";

interface Props {
	title: string;
	description?: string;
}

const {
	title,
	description = "Bizintellis helps organizations plan, implement, and run Oracle Cloud—with advisory, delivery, and support that speaks to strategy, platform, and economics in one thread.",
} = Astro.props;

const fullTitle = title.includes("Bizintellis") ? title : `${title} | Bizintellis Oracle Practice`;
---

<!doctype html>
<html lang="en" data-theme="dark">
	<head>
		<script is:inline>
			(function () {
				try {
					var t = localStorage.getItem("bizintellis-theme");
					if (t === "light" || t === "dark") document.documentElement.setAttribute("data-theme", t);
				} catch (e) {}
			})();
		</script>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
		<title>{fullTitle}</title>
	</head>
	<body>
		<slot />
		<div class="cursor-orbit" aria-hidden="true">
			<div class="cursor-orbit__dot"></div>
		</div>
		<WhatsAppSticky />
		<MotionInit />
		<script is:inline>
			(function () {
				function reduced() {
					return window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;
				}

				function finePointer() {
					return window.matchMedia && window.matchMedia("(pointer: fine)").matches;
				}

				function initCursor() {
					if (reduced() || !finePointer()) return;

					var root = document.documentElement;
					var orbit = document.querySelector(".cursor-orbit");
					if (!orbit) return;

					var tx = window.innerWidth * 0.5;
					var ty = window.innerHeight * 0.5;
					var x = tx;
					var y = ty;
					var raf = 0;
					var visible = false;

					function render() {
						raf = 0;
						x += (tx - x) * 0.16;
						y += (ty - y) * 0.16;
						root.style.setProperty("--cursor-x", x.toFixed(2));
						root.style.setProperty("--cursor-y", y.toFixed(2));
						if (!raf) raf = window.requestAnimationFrame(render);
					}

					function onMove(e) {
						tx = e.clientX;
						ty = e.clientY;
						if (!visible) {
							visible = true;
							orbit.classList.add("is-visible");
						}
						if (!raf) raf = window.requestAnimationFrame(render);
					}

					function onLeave() {
						visible = false;
						orbit.classList.remove("is-visible");
					}

					window.addEventListener("pointermove", onMove, { passive: true });
					window.addEventListener("pointerdown", onMove, { passive: true });
					window.addEventListener("blur", onLeave);
					document.addEventListener("mouseleave", onLeave);
				}

				if (document.readyState === "loading") {
					document.addEventListener("DOMContentLoaded", initCursor);
				} else {
					initCursor();
				}
			})();
		</script>
	</body>
</html>
