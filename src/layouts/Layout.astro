---
import "../styles/global.css";
import "../styles/animations.css";
import MotionInit from "../components/MotionInit.astro";
import WhatsAppSticky from "../components/WhatsAppSticky.astro";

interface Props {
	title: string;
	description?: string;
}

const {
	title,
	description = "Bizintellis helps organizations plan, implement, and run Oracle Cloud—with advisory, delivery, and support that speaks to strategy, platform, and economics in one thread.",
} = Astro.props;

const fullTitle = title.includes("Bizintellis") ? title : `${title} | Bizintellis Oracle Practice`;
---

<!doctype html>
<html lang="en" data-theme="dark">
	<head>
		<script is:inline>
			(function () {
				try {
					var t = localStorage.getItem("bizintellis-theme");
					if (t === "light" || t === "dark") document.documentElement.setAttribute("data-theme", t);
				} catch (e) {}
			})();
		</script>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
		<title>{fullTitle}</title>
	</head>
	<body>
		<slot />
		<WhatsAppSticky />
		<MotionInit />
	</body>
</html>
