---
import PageShell from "../layouts/PageShell.astro";
---

<PageShell title="Page not found — Bizintellis" description="The page you requested could not be found.">
	<section class="section" style="padding: 5rem 0;">
		<div class="wrap">
			<h1 class="motion-reveal">Page not found</h1>
			<p class="motion-reveal">The link may be outdated or the page may have moved.</p>
			<p class="motion-reveal">
				<a href="/" class="btn btn--primary">Back to home</a>
			</p>
		</div>
	</section>
</PageShell>
