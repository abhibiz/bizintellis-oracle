---
import PageShell from "../layouts/PageShell.astro";
import { siteImages } from "../data/siteImages";
---

<PageShell
	title="Contact — Bizintellis Oracle practice"
	description="Reach the Bizintellis Oracle practice to plan a confidential introductory conversation."
>
	<section class="section section--accent">
		<div class="wrap">
			<p class="eyebrow motion-reveal">Contact</p>
			<h1 class="motion-reveal">Plan a conversation</h1>
			<p class="motion-reveal" style="max-width: 58ch;">
				This site is built for prospective clients. Replace the placeholders below with your routing email, calendar link, and office details—or
				connect your CRM form action.
			</p>
		</div>
	</section>

	<section class="section">
		<div class="wrap contact-layout">
			<div>
				<div class="grid-2" data-motion-stagger>
					<div class="card motion-stagger__item">
						<h2 style="font-size: 1.25rem;">How to reach Bizintellis</h2>
						<p><strong>Email:</strong> oracle-practice@bizintellis.com</p>
						<p><strong>Engagement:</strong> Introductory calls are typically 30 minutes, focused on fit and next steps.</p>
						<p style="margin-bottom: 0;">
							<strong>Note:</strong> Update these fields in <code>src/pages/contact.astro</code> with production contact information.
						</p>
					</div>
					<div class="card motion-stagger__item">
						<h2 style="font-size: 1.25rem;">What to include</h2>
						<ul>
							<li>Industry and geography</li>
							<li>Oracle products in scope (Cloud ERP, HCM, SCM, etc.)</li>
							<li>Where you are: assess, implement, optimize, or run</li>
							<li>Sponsorship across business, technology, and finance (names optional)</li>
						</ul>
					</div>
				</div>

				<form class="card motion-reveal" style="margin-top: 1.5rem;" method="post" action="#">
					<h2 style="font-size: 1.25rem; margin-bottom: 1rem;">Message (wire to your form backend)</h2>
					<p style="font-size: 0.9375rem; margin-bottom: 1rem;">
						Hook this form to Formspree, Netlify Forms, or your API. Fields are semantic HTML for easy integration.
					</p>
					<div style="display: grid; gap: 1rem;">
						<label>
							<span style="display: block; font-weight: 600; font-size: 0.875rem; margin-bottom: 0.35rem;">Name</span>
							<input
								type="text"
								name="name"
								required
								style="width: 100%; padding: 0.65rem 0.75rem; border-radius: 8px; border: 1px solid var(--color-border); font: inherit;"
							/>
						</label>
						<label>
							<span style="display: block; font-weight: 600; font-size: 0.875rem; margin-bottom: 0.35rem;">Work email</span>
							<input
								type="email"
								name="email"
								required
								style="width: 100%; padding: 0.65rem 0.75rem; border-radius: 8px; border: 1px solid var(--color-border); font: inherit;"
							/>
						</label>
						<label>
							<span style="display: block; font-weight: 600; font-size: 0.875rem; margin-bottom: 0.35rem;">How you orient</span>
							<select
								name="role"
								style="width: 100%; padding: 0.65rem 0.75rem; border-radius: 8px; border: 1px solid var(--color-border); font: inherit; background: var(--color-bg-mid);"
							>
								<option>Business / strategy</option>
								<option>Technology / security</option>
								<option>Finance / operations</option>
								<option>Other</option>
							</select>
						</label>
						<label>
							<span style="display: block; font-weight: 600; font-size: 0.875rem; margin-bottom: 0.35rem;">How can we help?</span>
							<textarea
								name="message"
								rows="5"
								style="width: 100%; padding: 0.65rem 0.75rem; border-radius: 8px; border: 1px solid var(--color-border); font: inherit; resize: vertical;"
							></textarea>
						</label>
						<button type="submit" class="btn btn--primary" style="justify-self: start;">Submit</button>
					</div>
				</form>
			</div>
			<figure class="contact-aside-figure motion-reveal">
				<img src={siteImages.contact.src} alt={siteImages.contact.alt} width="380" height="475" loading="lazy" decoding="async" />
			</figure>
		</div>
	</section>
</PageShell>
