---
import PageShell from "../layouts/PageShell.astro";
---

<PageShell
	title="Contact — Bizintellis Oracle practice"
	description="Reach the Bizintellis Oracle practice to plan a confidential introductory conversation."
>
	<section class="section section--accent">
		<div class="wrap">
			<p class="eyebrow motion-reveal">Contact</p>
			<h1 class="motion-reveal">Choose a package, then send your message</h1>
			<p class="motion-reveal" style="max-width: 62ch;">
				Select a package below. Then share your details and what you want to achieve.
			</p>
		</div>
	</section>

	<section class="section">
		<div class="wrap" style="max-width: 860px;">
			<section class="card motion-reveal package-card">
				<h2 style="font-size: 1.25rem; margin-bottom: 0.25rem;">Package</h2>
				<p style="font-size: 0.9375rem; margin-bottom: 1rem; color: var(--color-muted);">
					Pick the service package you want to discuss.
				</p>
				<label>
					<span class="label">Package</span>
					<select id="package" name="package" required class="field">
						<option value="" selected disabled>Select a package</option>
						<option value="idr-p2p">IDR / Procure to Pay optimization Services</option>
						<option value="ai-enablement">AI Enablement for Oracle Fusion Applications</option>
						<option value="fusion-analytics-reporting">Oracle Fusion Analytics &amp; Reporting Packages</option>
					</select>
				</label>
			</section>

			<form class="card motion-reveal contact-form" style="margin-top: 1.5rem;" method="post" action="#">
				<h2 style="font-size: 1.25rem; margin-bottom: 1rem;">Contact form</h2>
				<div class="contact-form__grid">
					<label>
						<span class="label">Name</span>
						<input type="text" name="name" required class="field" autocomplete="name" />
					</label>
					<label>
						<span class="label">Work email</span>
						<input type="email" name="email" required class="field" autocomplete="email" />
					</label>
					<label>
						<span class="label">Phone (optional)</span>
						<input type="tel" name="phone" class="field" autocomplete="tel" />
					</label>
					<label>
						<span class="label">Company (optional)</span>
						<input type="text" name="company" class="field" autocomplete="organization" />
					</label>
					<label class="contact-form__message">
						<span class="label">Message</span>
						<textarea name="message" rows="6" required class="field"></textarea>
					</label>
					<button type="submit" class="btn btn--primary" style="justify-self: start;">Submit</button>
				</div>
			</form>
		</div>
	</section>
</PageShell>

<style>
	.contact-form__grid {
		display: grid;
		gap: 1rem;
		grid-template-columns: 1fr;
	}

	.contact-form__message {
		grid-column: 1 / -1;
	}

	.label {
		display: block;
		font-weight: 600;
		font-size: 0.875rem;
		margin-bottom: 0.35rem;
	}

	.field {
		width: 100%;
		padding: 0.7rem 0.85rem;
		border-radius: 10px;
		border: 1px solid var(--color-border);
		background: color-mix(in oklab, var(--color-bg-mid), transparent 12%);
		color: var(--color-ink);
		font: inherit;
		transition: border-color var(--dur-2) ease, box-shadow var(--dur-2) var(--ease-out-quint), background var(--dur-2) ease;
	}

	.field:focus {
		outline: none;
		border-color: color-mix(in oklab, var(--color-primary), var(--color-border-strong) 55%);
		box-shadow: var(--ring);
		background: color-mix(in oklab, var(--color-bg-mid), transparent 6%);
	}
</style>
